{
  "manifest_version": 3,
  "name": "림버스 크롤러",
  "version": "1.2",
  "description": "나무위키 페이지 텍스트를 로컬 서버에 저장",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost/*", "https://namu.wiki/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "림버스 크롤러"
  },
  "commands": {
    "crawl-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+K"
      },
      "description": "현재 페이지 크롤링"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
